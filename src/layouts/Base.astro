---
import {
	EmDashHead,
	EmDashBodyStart,
	EmDashBodyEnd,
} from "emdash/ui";
import { createPublicPageContext } from "emdash/page";
import "../styles/elkhorn.css";

interface Props {
	title: string;
	description?: string | null;
	content?: { collection: string; id: string; slug?: string | null };
}

const { title, description, content: contentRef } = Astro.props;

const siteTitle = "Elk Horn Painting";
const fullTitle = title?.includes(siteTitle) ? title : `${title} — ${siteTitle}`;

const pageCtx = createPublicPageContext({
	Astro,
	kind: contentRef ? "content" : "custom",
	pageType: "website",
	title: fullTitle,
	description,
	siteName: siteTitle,
});

const isLoggedIn = !!Astro.locals.user;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Open+Sans:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{fullTitle}</title>
		<EmDashHead context={pageCtx} />
	</head>
	<body>
		<EmDashBodyStart context={pageCtx} />

		<!-- Top Review Bar -->
		<div class="top-bar">
			<div class="top-bar-inner">
				<span class="review-badge">⭐⭐⭐⭐⭐ Google</span>
				<span class="review-badge">⭐⭐⭐⭐⭐ Angi</span>
				<span class="review-badge">⭐⭐⭐⭐⭐ Yelp</span>
				<span class="review-badge">⭐⭐⭐⭐⭐ Nextdoor</span>
				<span class="review-badge">⭐⭐⭐⭐⭐ Facebook</span>
			</div>
		</div>

		<!-- Navigation -->
		<header class="site-header">
			<nav class="nav-inner">
				<a href="/" class="site-logo">
					<span class="logo-text">ELK HORN</span>
					<span class="logo-sub">PAINTING</span>
				</a>
				<div class="nav-links">
					<a href="/#services">Services</a>
					<a href="/#reviews">Reviews</a>
					<a href="/#contact">Contact</a>
					{isLoggedIn && <a href="/_emdash/admin" class="nav-admin">Admin</a>}
				</div>
				<a href="tel:7205071738" class="phone-cta">
					<span class="phone-icon">📞</span>
					<span>(720) 507-1738</span>
				</a>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<!-- Footer -->
		<footer class="site-footer">
			<div class="footer-inner">
				<div class="footer-grid">
					<div class="footer-brand">
						<div class="footer-logo-text">ELK HORN PAINTING</div>
						<p>Professional painting services in Castle Rock & Denver, Colorado.</p>
						<p>Licensed & Insured</p>
					</div>
					<div class="footer-nav">
						<h4>Services</h4>
						<ul>
							<li><a href="/#services">Exterior Painting</a></li>
							<li><a href="/#services">Interior Painting</a></li>
							<li><a href="/#services">Cabinet Painting</a></li>
							<li><a href="/#services">Fence & Deck Staining</a></li>
							<li><a href="/#services">Commercial Painting</a></li>
						</ul>
					</div>
					<div class="footer-nav">
						<h4>Contact</h4>
						<ul>
							<li><a href="tel:7205071738">(720) 507-1738</a></li>
							<li><a href="mailto:office@elkhornpainting.com">office@elkhornpainting.com</a></li>
							<li>Castle Rock, CO</li>
							<li>Denver Metro Area</li>
						</ul>
					</div>
				</div>
				<div class="footer-bottom">
					<p>&copy; {new Date().getFullYear()} Elk Horn Painting. All rights reserved.</p>
					<p class="powered-by">Powered by <a href="https://emdashcms.com">EmDash</a></p>
				</div>
			</div>
		</footer>

		<EmDashBodyEnd context={pageCtx} />
	</body>
</html>
