---
import Base from "../layouts/Base.astro";
---

<Base title="Elk Horn Painting" description="Professional painting services in Castle Rock & Denver, Colorado.">
	<style>
		:root{--green:#2C4A3E;--green-dark:#1a2e26;--orange:#E87722;--orange-hover:#d16a1e;--off-white:#f5f5f0;--gray:#666;--light-gray:#e0e0e0}
		.elk h1,.elk h2,.elk h3,.elk h4{font-family:'Oswald',sans-serif;text-transform:uppercase;letter-spacing:0.02em;line-height:1.2}
		.hero{position:relative;min-height:80vh;display:flex;align-items:center;overflow:hidden}
		.hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;filter:brightness(0.35)}
		.hero-inner{position:relative;z-index:1;max-width:1200px;margin:0 auto;padding:60px 24px;display:grid;grid-template-columns:1fr 420px;gap:60px;align-items:center;width:100%}
		.hero-content{color:#fff}
		.hero-content h1{font-size:48px;font-weight:700;margin-bottom:20px;color:#fff}
		.hero-content h1 span{color:var(--orange)}
		.hero-content>p{font-size:18px;opacity:0.9;margin-bottom:24px;line-height:1.7}
		.hero-badges{display:flex;gap:16px;flex-wrap:wrap}
		.hero-badge{background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.25);padding:8px 16px;border-radius:6px;font-size:14px;font-weight:600;color:#fff}
		.lead-form{background:#fff;border-radius:12px;padding:32px;box-shadow:0 20px 60px rgba(0,0,0,0.3)}
		.lead-form h3{font-family:'Oswald',sans-serif;font-size:24px;color:var(--green);margin-bottom:4px;text-transform:uppercase}
		.form-sub{font-size:14px;color:var(--gray);margin-bottom:20px}
		.form-group{margin-bottom:14px}
		.form-group input,.form-group select,.form-group textarea{width:100%;padding:12px 16px;border:2px solid var(--light-gray);border-radius:8px;font-size:15px;font-family:inherit;transition:border-color 0.2s}
		.form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:var(--orange)}
		.btn-submit{width:100%;padding:14px;background:var(--orange);color:#fff;border:none;border-radius:8px;font-family:'Oswald',sans-serif;font-size:18px;font-weight:600;text-transform:uppercase;letter-spacing:1px;cursor:pointer;transition:background 0.2s}
		.btn-submit:hover{background:var(--orange-hover)}
		.elk-section{padding:80px 0}
		.elk-section-alt{background:var(--off-white)}
		.elk-inner{max-width:1200px;margin:0 auto;padding:0 24px}
		.elk-header{text-align:center;margin-bottom:48px}
		.elk-header h2{font-size:36px;color:var(--green);margin-bottom:12px}
		.elk-divider{width:60px;height:4px;background:var(--orange);margin:0 auto 16px}
		.elk-header>p{font-size:17px;color:var(--gray);max-width:600px;margin:0 auto}
		.services-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:24px}
		.service-card{background:#fff;border-radius:12px;padding:32px 24px;text-align:center;box-shadow:0 4px 16px rgba(0,0,0,0.06);transition:transform 0.2s,box-shadow 0.2s;border:2px solid transparent}
		.service-card:hover{transform:translateY(-4px);box-shadow:0 8px 30px rgba(0,0,0,0.1);border-color:var(--orange)}
		.service-card-icon{font-size:40px;margin-bottom:16px}
		.service-card h3{font-size:18px;color:var(--green);margin-bottom:10px}
		.service-card p{font-size:14px;color:var(--gray);line-height:1.6}
		.trust-row{display:flex;justify-content:center;gap:40px;flex-wrap:wrap;padding:20px 0}
		.trust-badge{display:flex;align-items:center;gap:12px}
		.trust-badge-icon{font-size:32px}
		.trust-badge-text{font-family:'Oswald',sans-serif;font-size:16px;font-weight:600;color:var(--green);text-transform:uppercase}
		.testimonials-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px}
		.testimonial-card{background:#fff;border-radius:12px;padding:28px;box-shadow:0 4px 16px rgba(0,0,0,0.06);border-left:4px solid var(--orange)}
		.testimonial-stars{color:var(--orange);font-size:18px;margin-bottom:12px}
		.testimonial-quote{font-size:15px;color:#444;line-height:1.7;margin-bottom:16px;font-style:italic}
		.testimonial-author{display:flex;justify-content:space-between;align-items:center}
		.testimonial-name{font-weight:700;color:var(--green)}
		.testimonial-source{font-size:13px;color:var(--gray);background:var(--off-white);padding:4px 10px;border-radius:12px}
		.cta-banner{background:var(--green);color:#fff;padding:60px 0;text-align:center}
		.cta-banner h2{font-size:36px;margin-bottom:12px;color:#fff}
		.cta-banner>div>p{font-size:18px;opacity:0.9;margin-bottom:28px}
		.cta-btn{display:inline-block;background:var(--orange);color:#fff;padding:16px 40px;border-radius:8px;font-family:'Oswald',sans-serif;font-size:20px;font-weight:600;text-transform:uppercase;letter-spacing:1px;transition:background 0.2s;text-decoration:none}
		.cta-btn:hover{background:var(--orange-hover)}
		.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px}
		.contact-info h3{font-size:22px;color:var(--green);margin-bottom:24px}
		.contact-item{display:flex;gap:16px;margin-bottom:20px;align-items:flex-start}
		.contact-icon{font-size:24px;flex-shrink:0;width:36px;text-align:center}
		.contact-item strong{display:block;color:var(--green);margin-bottom:2px}
		.contact-item p{margin:0;color:var(--gray)}
		.contact-item a{color:var(--orange);text-decoration:none}
		@media(max-width:768px){
			.hero-inner{grid-template-columns:1fr;gap:32px;padding:40px 20px}
			.hero-content h1{font-size:32px}
			.contact-grid{grid-template-columns:1fr}
			.trust-row{flex-direction:column;align-items:center;gap:20px}
		}
	</style>

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet" />

	<div class="elk">
		<section class="hero">
			<div class="hero-bg" style="background-image: url('https://images.pexels.com/photos/8961438/pexels-photo-8961438.jpeg?auto=compress&cs=tinysrgb&w=1920');"></div>
			<div class="hero-inner">
				<div class="hero-content">
					<h1>CASTLE ROCK &amp; DENVER'S<br /><span>MOST TRUSTED</span><br />PAINTING COMPANY</h1>
					<p>Transforming homes and businesses with expert craftsmanship, premium materials, and attention to detail since day one.</p>
					<div class="hero-badges">
						<div class="hero-badge">&#10003; Licensed &amp; Insured</div>
						<div class="hero-badge">&#10003; Free Estimates</div>
						<div class="hero-badge">&#10003; 5-Star Rated</div>
					</div>
				</div>
				<div class="lead-form">
					<h3>Get Your Free Estimate</h3>
					<p class="form-sub">No obligation — we'll get back to you within 24 hours</p>
					<form>
						<div class="form-group"><input type="text" placeholder="Full Name" required /></div>
						<div class="form-group"><input type="tel" placeholder="Phone Number" required /></div>
						<div class="form-group"><input type="email" placeholder="Email Address" /></div>
						<div class="form-group">
							<select>
								<option value="">Select Service Needed</option>
								<option value="exterior">Exterior Painting</option>
								<option value="interior">Interior Painting</option>
								<option value="cabinet">Cabinet Painting</option>
								<option value="staining">Fence and Deck Staining</option>
								<option value="commercial">Commercial Painting</option>
							</select>
						</div>
						<div class="form-group"><textarea rows="3" placeholder="Tell us about your project..."></textarea></div>
						<button type="submit" class="btn-submit">Get My Free Estimate</button>
					</form>
				</div>
			</div>
		</section>

		<section class="elk-section elk-section-alt" id="services">
			<div class="elk-inner">
				<div class="elk-header">
					<h2>Our Services</h2>
					<div class="elk-divider"></div>
					<p>From interior refreshes to full exterior transformations, we do it all with precision and care.</p>
				</div>
				<div class="services-grid">
					<div class="service-card"><div class="service-card-icon">&#127968;</div><h3>Exterior Painting</h3><p>Transform your curb appeal with professional exterior painting. Premium paints for Colorado climate.</p></div>
					<div class="service-card"><div class="service-card-icon">&#127912;</div><h3>Interior Painting</h3><p>Refresh your living spaces. Clean lines, smooth finishes, and zero-VOC paints for a healthy home.</p></div>
					<div class="service-card"><div class="service-card-icon">&#129717;</div><h3>Cabinet Painting</h3><p>Kitchen makeover without the cost of replacement. Factory-smooth finishes that last for years.</p></div>
					<div class="service-card"><div class="service-card-icon">&#129708;</div><h3>Fence and Deck</h3><p>Protect and beautify outdoor wood surfaces with professional staining and sealing services.</p></div>
					<div class="service-card"><div class="service-card-icon">&#127970;</div><h3>Commercial</h3><p>Professional painting for offices, retail, and commercial buildings. Minimal disruption, maximum impact.</p></div>
				</div>
			</div>
		</section>

		<section class="elk-section">
			<div class="elk-inner">
				<div class="trust-row">
					<div class="trust-badge"><div class="trust-badge-icon">&#127942;</div><div class="trust-badge-text">BBB Accredited</div></div>
					<div class="trust-badge"><div class="trust-badge-icon">&#11088;</div><div class="trust-badge-text">Nextdoor Faves</div></div>
					<div class="trust-badge"><div class="trust-badge-icon">&#128737;</div><div class="trust-badge-text">Licensed and Insured</div></div>
					<div class="trust-badge"><div class="trust-badge-icon">&#9989;</div><div class="trust-badge-text">500+ Projects</div></div>
				</div>
			</div>
		</section>

		<section class="elk-section elk-section-alt" id="reviews">
			<div class="elk-inner">
				<div class="elk-header">
					<h2>What Our Customers Say</h2>
					<div class="elk-divider"></div>
					<p>We let our work speak for itself, but our customers like to speak up too.</p>
				</div>
				<div class="testimonials-grid">
					<div class="testimonial-card"><div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="testimonial-quote">"Elk Horn did an amazing job on our exterior! Professional, on time, and outstanding attention to detail."</p><div class="testimonial-author"><span class="testimonial-name">Sarah M.</span><span class="testimonial-source">Google</span></div></div>
					<div class="testimonial-card"><div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="testimonial-quote">"Painted our entire interior - 12 rooms! Incredibly organized and the result exceeded our expectations."</p><div class="testimonial-author"><span class="testimonial-name">David R.</span><span class="testimonial-source">Google</span></div></div>
					<div class="testimonial-card"><div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="testimonial-quote">"They transformed our dated oak cabinets into beautiful modern white ones. The finish is so smooth!"</p><div class="testimonial-author"><span class="testimonial-name">Jennifer K.</span><span class="testimonial-source">Nextdoor</span></div></div>
					<div class="testimonial-card"><div class="testimonial-stars">&#9733;&#9733;&#9733;&#9733;&#9733;</div><p class="testimonial-quote">"Stained our fence and deck and they look brand new. Great price and great communication."</p><div class="testimonial-author"><span class="testimonial-name">Mike T.</span><span class="testimonial-source">Angi</span></div></div>
				</div>
			</div>
		</section>

		<section class="cta-banner">
			<div class="elk-inner">
				<h2>Ready to Transform Your Space?</h2>
				<p>Call us today for a free, no-obligation estimate.</p>
				<a href="tel:7205071738" class="cta-btn">Call (720) 507-1738</a>
			</div>
		</section>

		<section class="elk-section" id="contact">
			<div class="elk-inner">
				<div class="elk-header">
					<h2>Get In Touch</h2>
					<div class="elk-divider"></div>
				</div>
				<div class="contact-grid">
					<div class="contact-info">
						<h3>Contact Information</h3>
						<div class="contact-item"><div class="contact-icon">&#128222;</div><div><strong>Phone</strong><p><a href="tel:7205071738">(720) 507-1738</a></p></div></div>
						<div class="contact-item"><div class="contact-icon">&#9993;</div><div><strong>Email</strong><p><a href="mailto:office@elkhornpainting.com">office@elkhornpainting.com</a></p></div></div>
						<div class="contact-item"><div class="contact-icon">&#128205;</div><div><strong>Service Areas</strong><p>Castle Rock, CO and Denver Metro</p></div></div>
						<div class="contact-item"><div class="contact-icon">&#128336;</div><div><strong>Hours</strong><p>Mon-Sat: 7AM - 6PM</p></div></div>
					</div>
					<div class="contact-form-wrap">
						<div class="lead-form">
							<h3>Send Us a Message</h3>
							<p class="form-sub">We respond within 24 hours</p>
							<form>
								<div class="form-group"><input type="text" placeholder="Your Name" required /></div>
								<div class="form-group"><input type="tel" placeholder="Phone Number" required /></div>
								<div class="form-group"><input type="email" placeholder="Email Address" /></div>
								<div class="form-group"><textarea rows="4" placeholder="How can we help?"></textarea></div>
								<button type="submit" class="btn-submit">Send Message</button>
							</form>
						</div>
					</div>
				</div>
			</div>
		</section>
	</div>
</Base>
