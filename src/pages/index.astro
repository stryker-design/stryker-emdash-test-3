---
import Base from "../layouts/Base.astro";
---

<Base title="Professional Painting Services" description="Elk Horn Painting — Professional painting services in Castle Rock & Denver, Colorado.">
	
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero-bg" style="background-image: url('https://images.pexels.com/photos/8961438/pexels-photo-8961438.jpeg?auto=compress&cs=tinysrgb&w=1920');"></div>
		<div class="hero-inner">
			<div class="hero-content">
				<h1>
					CASTLE ROCK &amp; DENVER'S<br/>
					<span>MOST TRUSTED</span><br/>
					PAINTING COMPANY
				</h1>
				<p>
					Transforming homes and businesses with expert craftsmanship, 
					premium materials, and attention to detail since day one.
				</p>
				<div class="hero-badges">
					<div class="hero-badge">✓ Licensed &amp; Insured</div>
					<div class="hero-badge">✓ Free Estimates</div>
					<div class="hero-badge">✓ 5-Star Rated</div>
				</div>
			</div>
			
			<div class="lead-form">
				<h3>Get Your Free Estimate</h3>
				<p class="form-sub">No obligation — we'll get back to you within 24 hours</p>
				<form>
					<div class="form-group">
						<input type="text" placeholder="Full Name" required />
					</div>
					<div class="form-group">
						<input type="tel" placeholder="Phone Number" required />
					</div>
					<div class="form-group">
						<input type="email" placeholder="Email Address" />
					</div>
					<div class="form-group">
						<select>
							<option value="">Select Service Needed</option>
							<option value="exterior">Exterior Painting</option>
							<option value="interior">Interior Painting</option>
							<option value="cabinet">Cabinet Painting</option>
							<option value="staining">Fence &amp; Deck Staining</option>
							<option value="commercial">Commercial Painting</option>
						</select>
					</div>
					<div class="form-group">
						<textarea rows="3" placeholder="Tell us about your project..."></textarea>
					</div>
					<button type="submit" class="btn-submit">Get My Free Estimate →</button>
				</form>
			</div>
		</div>
	</section>

	<!-- Services Section -->
	<section class="section section-alt" id="services">
		<div class="section-inner">
			<div class="section-header">
				<h2>Our Services</h2>
				<div class="section-divider"></div>
				<p>From interior refreshes to full exterior transformations — we do it all with precision and care.</p>
			</div>
			<div class="services-grid">
				<div class="service-card">
					<div class="service-card-icon">🏠</div>
					<h3>Exterior Painting</h3>
					<p>Transform your home's curb appeal with our professional exterior painting services. We use premium paints rated for Colorado's demanding climate.</p>
				</div>
				<div class="service-card">
					<div class="service-card-icon">🎨</div>
					<h3>Interior Painting</h3>
					<p>Refresh your living spaces with expert interior painting. Clean lines, smooth finishes, and zero-VOC paints for a healthy home.</p>
				</div>
				<div class="service-card">
					<div class="service-card-icon">🪵</div>
					<h3>Cabinet Painting</h3>
					<p>Give your kitchen a complete makeover without the cost of replacement. Factory-smooth finishes that last for years.</p>
				</div>
				<div class="service-card">
					<div class="service-card-icon">🪜</div>
					<h3>Fence &amp; Deck Staining</h3>
					<p>Protect and beautify your outdoor wood surfaces with professional staining and sealing services.</p>
				</div>
				<div class="service-card">
					<div class="service-card-icon">🏢</div>
					<h3>Commercial Painting</h3>
					<p>Professional painting for offices, retail spaces, and commercial buildings. Minimal disruption, maximum impact.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Trust Badges -->
	<section class="section">
		<div class="section-inner">
			<div class="trust-row">
				<div class="trust-badge">
					<div class="trust-badge-icon">🏆</div>
					<div class="trust-badge-text">BBB Accredited</div>
				</div>
				<div class="trust-badge">
					<div class="trust-badge-icon">⭐</div>
					<div class="trust-badge-text">Nextdoor Faves 2022–2025</div>
				</div>
				<div class="trust-badge">
					<div class="trust-badge-icon">🛡️</div>
					<div class="trust-badge-text">Fully Licensed &amp; Insured</div>
				</div>
				<div class="trust-badge">
					<div class="trust-badge-icon">✅</div>
					<div class="trust-badge-text">500+ Projects Completed</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Testimonials Section -->
	<section class="section section-alt" id="reviews">
		<div class="section-inner">
			<div class="section-header">
				<h2>What Our Customers Say</h2>
				<div class="section-divider"></div>
				<p>We let our work speak for itself — but our customers like to speak up too.</p>
			</div>
			<div class="testimonials-grid">
				<div class="testimonial-card">
					<div class="testimonial-stars">★★★★★</div>
					<p class="testimonial-quote">"Elk Horn Painting did an amazing job on our exterior! The crew was professional, on time, and the attention to detail was outstanding. Our neighbors keep complimenting our house!"</p>
					<div class="testimonial-author">
						<span class="testimonial-name">Sarah M.</span>
						<span class="testimonial-source">Google</span>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="testimonial-stars">★★★★★</div>
					<p class="testimonial-quote">"We hired Elk Horn to paint our entire interior - 12 rooms! They were incredibly organized and the finished result exceeded our expectations. Highly recommend!"</p>
					<div class="testimonial-author">
						<span class="testimonial-name">David R.</span>
						<span class="testimonial-source">Google</span>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="testimonial-stars">★★★★★</div>
					<p class="testimonial-quote">"Best cabinet painting experience ever. They transformed our dated oak cabinets into beautiful modern white ones. The finish is so smooth — looks like new cabinets!"</p>
					<div class="testimonial-author">
						<span class="testimonial-name">Jennifer K.</span>
						<span class="testimonial-source">Nextdoor</span>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="testimonial-stars">★★★★★</div>
					<p class="testimonial-quote">"Elk Horn stained our fence and deck and they look brand new. Great price, great communication, and the crew cleaned up everything perfectly."</p>
					<div class="testimonial-author">
						<span class="testimonial-name">Mike T.</span>
						<span class="testimonial-source">Angi</span>
					</div>
				</div>
				<div class="testimonial-card">
					<div class="testimonial-stars">★★★★★</div>
					<p class="testimonial-quote">"We had our office suite painted over a weekend and Monday morning it was perfect. No smell, no mess, just beautiful new walls. Very professional team."</p>
					<div class="testimonial-author">
						<span class="testimonial-name">Lisa H.</span>
						<span class="testimonial-source">Yelp</span>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Banner -->
	<section class="cta-banner">
		<div class="section-inner">
			<h2>Ready to Transform Your Space?</h2>
			<p>Call us today for a free, no-obligation estimate. We'd love to hear about your project.</p>
			<a href="tel:7205071738" class="cta-btn">Call (720) 507-1738</a>
		</div>
	</section>

	<!-- Contact Section -->
	<section class="section" id="contact">
		<div class="section-inner">
			<div class="section-header">
				<h2>Get In Touch</h2>
				<div class="section-divider"></div>
			</div>
			<div class="contact-grid">
				<div class="contact-info">
					<h3>Contact Information</h3>
					<div class="contact-item">
						<div class="contact-icon">📞</div>
						<div>
							<strong>Phone</strong>
							<p><a href="tel:7205071738">(720) 507-1738</a></p>
						</div>
					</div>
					<div class="contact-item">
						<div class="contact-icon">✉️</div>
						<div>
							<strong>Email</strong>
							<p><a href="mailto:office@elkhornpainting.com">office@elkhornpainting.com</a></p>
						</div>
					</div>
					<div class="contact-item">
						<div class="contact-icon">📍</div>
						<div>
							<strong>Service Areas</strong>
							<p>Castle Rock, CO • Denver Metro Area</p>
						</div>
					</div>
					<div class="contact-item">
						<div class="contact-icon">🕐</div>
						<div>
							<strong>Hours</strong>
							<p>Monday – Saturday: 7:00 AM – 6:00 PM</p>
						</div>
					</div>
				</div>
				<div class="contact-form-wrap">
					<div class="lead-form">
						<h3>Send Us a Message</h3>
						<p class="form-sub">We respond within 24 hours</p>
						<form>
							<div class="form-group">
								<input type="text" placeholder="Your Name" required />
							</div>
							<div class="form-group">
								<input type="tel" placeholder="Phone Number" required />
							</div>
							<div class="form-group">
								<input type="email" placeholder="Email Address" />
							</div>
							<div class="form-group">
								<textarea rows="4" placeholder="How can we help?"></textarea>
							</div>
							<button type="submit" class="btn-submit">Send Message →</button>
						</form>
					</div>
				</div>
			</div>
		</div>
	</section>
</Base>
