---
import Base from "../layouts/Base.astro";
---

<Base title="Page Not Found">
	<section class="section" style="text-align: center; padding: 120px 20px;">
		<h1 style="font-family: var(--font-heading); font-size: 6rem; color: var(--elk-green); opacity: 0.3;">404</h1>
		<p style="font-size: 1.2rem; color: var(--elk-text-light); margin-bottom: 24px;">The page you're looking for doesn't exist.</p>
		<a href="/" class="cta-btn" style="background: var(--elk-orange); color: white;">Back to Home</a>
	</section>
</Base>
